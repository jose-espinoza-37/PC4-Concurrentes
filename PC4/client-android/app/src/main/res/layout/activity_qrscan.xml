<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/brand"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <ViewFlipper
        android:id="@+id/qrFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Vista 0: mostrar mi propio QR (generado por QR_GENERATE) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/qr_show_title"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <ImageView
                android:id="@+id/qrImage"
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:background="@android:color/white" />

            <TextView
                android:id="@+id/qrCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Vista 1: escanear el QR del otro dispositivo con CameraX + ML Kit -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.camera.view.PreviewView
                android:id="@+id/cameraPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:background="#88000000"
                android:textColor="@android:color/white"
                android:padding="12dp"
                android:gravity="center"
                android:text="@string/qr_scan_title" />
        </FrameLayout>
    </ViewFlipper>

    <Button
        android:id="@+id/btnToggleMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/qr_toggle" />
</LinearLayout>